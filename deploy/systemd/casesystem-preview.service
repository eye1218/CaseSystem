[Unit]
Description=CaseSystem Preview Service
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/workspace/CaseSystem
Environment=CASESYSTEM_ENVIRONMENT=preview
Environment=CASESYSTEM_COOKIE_SECURE=false
ExecStart=/root/workspace/CaseSystem/.venv/bin/uvicorn app.main:app --app-dir /root/workspace/CaseSystem/backend --host 0.0.0.0 --port 8010
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
